<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.controller.LoginController"
            prefWidth="1000"
            prefHeight="600">

    <!-- PANEL KIRI -->
    <left>

        <VBox alignment="CENTER"
              spacing="20"
              prefWidth="500"
              style="-fx-background-color:#2E7D32;">

            <Label text="💰"
                   style="-fx-font-size:80;" />

            <Label text="SISTEM LEDGER &amp; MUTASI"
                   style="-fx-font-size:28;
                          -fx-font-weight:bold;
                          -fx-text-fill:white;" />

            <Label text="Aplikasi Pengelolaan Transaksi&#10;Debit dan Kredit"
                   style="-fx-font-size:16;
                          -fx-text-fill:white;"
                   wrapText="true"/>

        </VBox>

    </left>

    <!-- PANEL KANAN -->
    <center>

        <VBox alignment="CENTER"
              spacing="15">

            <Label text="LOGIN"
                   style="-fx-font-size:28;
                          -fx-font-weight:bold;" />

            <Label text="Silakan masuk ke sistem"
                   style="-fx-text-fill:gray;" />

            <Label fx:id="lblNotif"
                   visible="false"
                   maxWidth="Infinity"
                   textAlignment="CENTER"
                   style="-fx-background-color:#F44336;
              -fx-text-fill:white;
              -fx-padding:12;
              -fx-font-size:14;
              -fx-font-weight:bold;
              -fx-background-radius:8;" />
            <TextField fx:id="txtUsername"
                       promptText="Username"
                       prefWidth="280"
                       prefHeight="40"/>

            <PasswordField fx:id="txtPassword"
                           promptText="Password"
                           prefWidth="280"
                           prefHeight="40"/>

            <Button text="LOGIN"
                    onAction="#login"
                    prefWidth="280"
                    prefHeight="45"
                    style="-fx-background-color:#2E7D32;
                           -fx-text-fill:white;
                           -fx-font-weight:bold;" />

            <Label text="Username : admin"
                   style="-fx-text-fill:gray;" />

            <Label text="Password : 123"
                   style="-fx-text-fill:gray;" />



        </VBox>

    </center>

</BorderPane>